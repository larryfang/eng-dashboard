# eng-dashboard — Environment Variables
# Copy this file to .env and fill in the values you need.
# Only the providers you actually use need credentials.

# ─── Git Providers ──────────────────────────────────────────────────────────
# GitLab (required if using GitLab as code platform)
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# GitHub (required if using GitHub as code platform)
GITHUB_TOKEN=
GITHUB_ORG=

# ─── Issue Trackers ─────────────────────────────────────────────────────────
# Jira — API Token auth (required if using Jira as issue tracker)
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_URL=https://yoursite.atlassian.net

# Jira — OAuth 2.0 auth (alternative to API token)
# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=
# JIRA_OAUTH_REFRESH_TOKEN=
# JIRA_OAUTH_ACCESS_TOKEN=
# JIRA_OAUTH_TOKEN_EXPIRY=
# ATLASSIAN_CLOUD_ID=

# Linear (required if using Linear as issue tracker)
# LINEAR_API_KEY=

# Monday.com (required if using Monday as issue tracker)
# MONDAY_TOKEN=

# Asana (required if using Asana as issue tracker)
# ASANA_TOKEN=

# ─── Service Catalog ────────────────────────────────────────────────────────
# Port.io (optional — enables service catalog features)
PORT_CLIENT_ID=
PORT_CLIENT_SECRET=

# ─── Security ───────────────────────────────────────────────────────────────
# Snyk (optional — enables security vulnerability tracking)
SNYK_TOKEN=
SNYK_ORG_ID=

# ─── Notifications ──────────────────────────────────────────────────────────
# Telegram (optional — enables alert notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email — provider selection: "mailgun" or "gmail"
# EMAIL_PROVIDER=

# Mailgun (optional — enables email notifications via Mailgun)
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_FROM_EMAIL=
# MAILGUN_BASE_URL=
# MAILGUN_REGION=

# Gmail SMTP (optional — enables email notifications via Gmail)
# GMAIL_EMAIL=
# GMAIL_APP_PASSWORD=
# GMAIL_FROM_EMAIL=
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=465

# Email alert recipient(s), comma-separated
# ALERT_EMAIL_TO=

# Jira report email recipient
# JIRA_REPORT_RECIPIENT=

# ─── Alert Thresholds ──────────────────────────────────────────────────────
ALERT_COOLDOWN_MINUTES=240
ALERT_DORA_DEGRADATION_PCT=20
QUIET_ENGINEER_DAYS=10
ALERT_JIRA_STALE_DAYS=7

# ─── AI / LLM (optional — enables AI-powered summaries) ────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Advanced / Override ───────────────────────────────────────────────────
# Custom SQLite database URL (default: sqlite:///data/eng_dashboard.db)
# DATABASE_URL=

# Custom config file path (default: config/organization.yaml)
# SETU_CONFIG=

# Atlassian site URL for epic links in alerts
# ATLASSIAN_SITE_URL=
